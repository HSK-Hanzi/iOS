# fastlane snapshot configuration — see https://docs.fastlane.tools/actions/snapshot/
# Drives the `GenerateScreenshots` UI test to capture the App Store screenshot set.

devices([
  "iPhone 17 Pro Max", # 6.9" — the required large-iPhone display size
  "iPad Pro 13-inch (M4)" # 13" — the required large-iPad display size
])

languages(["en-US"])

scheme("Zili")

# The scheme defaults to the "Unit Tests" plan, which excludes ZiliUITests; the screenshot run
# needs the "UI Tests" plan, or `only_testing` below would match nothing.
testplan("UI Tests")
only_testing(["ZiliUITests/GenerateScreenshots"])

output_directory("./fastlane/screenshots")
clear_previous_screenshots(true)

# Overlay a clean 9:41 status bar with full signal and battery.
override_status_bar(true)
